# BudFin API — Environment Variables
# Copy this file to apps/api/.env and fill in the values.
# Never commit the actual .env file (it is in .gitignore).

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# In Docker Compose, host is the service name "db".
# For local dev, use localhost with a local Postgres instance.
DATABASE_URL=postgresql://app_user:changeme@localhost:5432/budfindb

# Used by docker-compose.yml to set the Postgres superuser password.
DB_PASSWORD=changeme

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug
LOG_LEVEL=debug

# ── Authentication ────────────────────────────────────────────────────────────
# Path to the EC P-256 private key (PEM format) used to sign JWTs.
# Generate with:
#   mkdir -p secrets
#   openssl ecparam -name P-256 -genkey -noout -out secrets/jwt_private_key.pem
# In production this is injected as a Docker secret mounted at /run/secrets/
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private_key.pem

# ── Salary Encryption ─────────────────────────────────────────────────────────
# Path to a file containing the AES-256 key used to encrypt salary fields.
# Generate with:
#   openssl rand -base64 32 > secrets/salary_encryption_key.txt
# In production this is injected as a Docker secret mounted at /run/secrets/
SALARY_ENCRYPTION_KEY=./secrets/salary_encryption_key.txt
