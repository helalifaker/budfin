node_modules/
.vscode/
package-lock.json
.worktrees/

# Environment files — never commit secrets
.env
.env.*
!.env.example

# Build outputs
dist/
build/
apps/*/dist/
apps/*/build/

# TypeScript incremental build info
*.tsbuildinfo

# ESLint cache
.eslintcache

# Test coverage
coverage/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# Local SQLite (if used for local dev)
apps/api/prisma/*.db
apps/api/prisma/*.db-journal

# Secrets directory (generated keys, never commit)
secrets/

# Python artifacts (should not exist in this Node.js project)
.mypy_cache/

# Git worktrees (recreated on demand)
.worktrees/

# Claude session artifacts — tracked as GitHub Issues instead
/plans/
/tasks/
