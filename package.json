{
	"name": "budfin",
	"private": true,
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"dev": "pnpm --parallel -r dev",
		"build": "pnpm -r build",
		"lint": "pnpm -r lint",
		"typecheck": "pnpm -r typecheck",
		"test": "pnpm -r test",
		"lint:md": "markdownlint --config .markdownlint.json '**/*.md' --ignore-path .markdownlintignore",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:all": "pnpm lint && pnpm lint:md && pnpm format:check",
		"prepare": "husky"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"esbuild",
			"prisma"
		],
		"overrides": {
			"fastify@>=5.7.2 <=5.8.0": ">=5.8.1",
			"flatted@<3.4.0": ">=3.4.0",
			"undici@>=7.0.0 <7.24.0": ">=7.24.0",
			"undici@>=7.17.0 <7.24.0": ">=7.24.0"
		},
		"auditConfig": {
			"ignoreCves": [
				"CVE-2023-30533",
				"CVE-2024-22363"
			]
		}
	},
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"eslint": "^9.0.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"husky": "^9.1.0",
		"lint-staged": "^15.5.0",
		"markdownlint-cli": "^0.48.0",
		"prettier": "^3.8.0",
		"typescript": "5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mjs,cjs}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{json,css}": [
			"prettier --write"
		],
		"*.md": [
			"prettier --write",
			"markdownlint --fix --config .markdownlint.json --ignore-path .markdownlintignore"
		]
	}
}
