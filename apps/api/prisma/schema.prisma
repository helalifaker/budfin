// ── Staffing & Staff Costs (Epic 3) ──────────────────────────────────────────

model Employee {
  id                      Int       @id @default(autoincrement())
  versionId               Int       @map("version_id")
  employeeCode            String    @map("employee_code") @db.VarChar(20)
  name                    String    @db.VarChar(200)
  functionRole            String    @map("function_role") @db.VarChar(100)
  department              String    @db.VarChar(50)
  status                  String    @default("Existing") @db.VarChar(10)
  joiningDate             DateTime  @map("joining_date") @db.Date
  paymentMethod           String    @map("payment_method") @db.VarChar(50)
  isSaudi                 Boolean   @default(false) @map("is_saudi")
  isAjeer                 Boolean   @default(false) @map("is_ajeer")
  isTeaching              Boolean   @default(false) @map("is_teaching")
  hourlyPercentage        Decimal   @default(1.0000) @map("hourly_percentage") @db.Decimal(5, 4)
  baseSalary              Bytes     @map("base_salary")
  housingAllowance        Bytes     @map("housing_allowance")
  transportAllowance      Bytes     @map("transport_allowance")
  responsibilityPremium   Bytes     @default(dbgenerated()) @map("responsibility_premium")
  hsaAmount               Bytes     @default(dbgenerated()) @map("hsa_amount")
  augmentation            Bytes     @default(dbgenerated()) @map("augmentation")
  augmentationEffectiveDate DateTime? @map("augmentation_effective_date") @db.Date
  ajeerAnnualLevy         Decimal   @default(0) @map("ajeer_annual_levy") @db.Decimal(15, 4)
  ajeerMonthlyFee         Decimal   @default(0) @map("ajeer_monthly_fee") @db.Decimal(15, 4)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy               Int       @map("created_by")
  updatedBy               Int?      @map("updated_by")

  version            BudgetVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  creator            User             @relation("EmployeeCreator", fields: [createdBy], references: [id])
  updater            User?            @relation("EmployeeUpdater", fields: [updatedBy], references: [id])
  monthlyStaffCosts  MonthlyStaffCost[]
  eosProvision       EosProvision?

  @@unique([versionId, employeeCode], map: "uq_employee_code_version")
  @@index([versionId], map: "idx_employees_version")
  @@index([versionId, department], map: "idx_employees_department")
  @@index([versionId, status], map: "idx_employees_status")
  @@map("employees")
}

