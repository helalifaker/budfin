// Prisma schema for BudFin API
// Documentation: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models will be defined during feature implementation.
// See docs/tdd/02_component_design.md for the entity model.

model SchemaVersion {
  id        Int      @id @default(1)
  version   String   @default("0.0.1")
  appliedAt DateTime @default(now()) @map("applied_at")

  @@map("schema_version")
}

// ── Authentication & RBAC (Epic 11) ─────────────────────────────────────────

enum UserRole {
  Admin
  BudgetOwner
  Editor
  Viewer

  @@map("user_role")
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique @db.VarChar(255)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  role               UserRole  @default(Viewer)
  isActive           Boolean   @default(true) @map("is_active")
  failedAttempts     Int       @default(0) @map("failed_attempts")
  lockedUntil        DateTime? @map("locked_until") @db.Timestamptz
  forcePasswordReset Boolean   @default(false) @map("force_password_reset")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  refreshTokens RefreshToken[]
  auditEntries  AuditEntry[]
  configUpdates SystemConfig[] @relation("ConfigUpdatedBy")

  // Master Data relations (Epic 7)
  createdAccounts      ChartOfAccount[] @relation("AccountCreator")
  updatedAccounts      ChartOfAccount[] @relation("AccountUpdater")
  createdAcademicYears AcademicYear[]   @relation("AcademicYearCreator")
  updatedAcademicYears AcademicYear[]   @relation("AcademicYearUpdater")
  createdNationalities Nationality[]    @relation("NationalityCreator")
  updatedNationalities Nationality[]    @relation("NationalityUpdater")
  createdTariffs       Tariff[]         @relation("TariffCreator")
  updatedTariffs       Tariff[]         @relation("TariffUpdater")
  createdDepartments   Department[]     @relation("DepartmentCreator")
  updatedDepartments   Department[]     @relation("DepartmentUpdater")
  updatedAssumptions   Assumption[]     @relation("AssumptionUpdater")

  // Version Management relations (Epic 10)
  createdVersions     BudgetVersion[]    @relation("VersionCreator")
  updatedVersions     BudgetVersion[]    @relation("VersionUpdater")
  lockedFiscalPeriods FiscalPeriod[]     @relation("FiscalPeriodLocker")
  updatedFiscalPeriods FiscalPeriod[]   @relation("FiscalPeriodUpdater")
  importedActuals     ActualsImportLog[] @relation("ActualsImporter")

  // Enrollment & Capacity relations (Epic 1)
  createdHeadcounts  EnrollmentHeadcount[] @relation("HeadcountCreator")
  updatedHeadcounts  EnrollmentHeadcount[] @relation("HeadcountUpdater")
  createdDetails     EnrollmentDetail[]    @relation("DetailCreator")
  updatedDetails     EnrollmentDetail[]    @relation("DetailUpdater")

  // Calculation audit relations
  triggeredCalculations CalculationAuditLog[] @relation("CalculationTriggeredBy")

  // Revenue relations (Epic 2)
  createdFeeGrids      FeeGrid[]          @relation("FeeGridCreator")
  updatedFeeGrids      FeeGrid[]          @relation("FeeGridUpdater")
  createdDiscounts     DiscountPolicy[]   @relation("DiscountCreator")
  updatedDiscounts     DiscountPolicy[]   @relation("DiscountUpdater")
  createdRevenueSettings VersionRevenueSettings[] @relation("VersionRevenueSettingsCreator")
  updatedRevenueSettings VersionRevenueSettings[] @relation("VersionRevenueSettingsUpdater")
  createdOtherRevenue  OtherRevenueItem[] @relation("OtherRevenueCreator")
  updatedOtherRevenue  OtherRevenueItem[] @relation("OtherRevenueUpdater")
  calculatedRevenue    MonthlyRevenue[]   @relation("RevenueCalculator")
  calculatedOtherRevenue MonthlyOtherRevenue[] @relation("OtherRevenueCalculator")

  // Staffing relations (Epic 3)
  createdEmployees     Employee[]         @relation("EmployeeCreator")
  updatedEmployees     Employee[]         @relation("EmployeeUpdater")
  costCalculations     MonthlyStaffCost[] @relation("CostCalculator")
  categoryCostCalculations CategoryMonthlyCost[] @relation("CategoryCostCalculator")

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  familyId  String   @map("family_id") @db.Uuid
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId], map: "idx_refresh_tokens_family")
  @@index([userId, isRevoked], map: "idx_refresh_tokens_user_active")
  @@index([expiresAt], map: "idx_refresh_tokens_expires")
  @@map("refresh_tokens")
}

model SystemConfig {
  key         String   @id @db.VarChar(100)
  value       String   @db.Text
  dataType    String   @default("string") @map("data_type") @db.VarChar(20)
  description String?  @db.Text
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy   Int?     @map("updated_by")

  updatedByUser User? @relation("ConfigUpdatedBy", fields: [updatedBy], references: [id])

  @@map("system_config")
}

model AuditEntry {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  operation  String   @db.VarChar(50)
  tableName  String?  @map("table_name") @db.VarChar(100)
  recordId   Int?     @map("record_id")
  oldValues  Json?    @map("old_values") @db.JsonB
  newValues  Json?    @map("new_values") @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userEmail  String?  @map("user_email") @db.VarChar(255)
  sessionId  String?  @map("session_id") @db.VarChar(100)
  auditNote  String?  @map("audit_note") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt], map: "idx_audit_entries_created")
  @@index([userId], map: "idx_audit_entries_user")
  @@index([tableName, recordId], map: "idx_audit_entries_table_record")
  @@index([operation], map: "idx_audit_entries_operation")
  @@map("audit_entries")
}

// ── Master Data Management (Epic 7) ──────────────────────────────────────────

enum AccountType {
  REVENUE
  EXPENSE
  ASSET
  LIABILITY

  @@map("account_type")
}

enum CenterType {
  PROFIT_CENTER
  COST_CENTER

  @@map("center_type")
}

enum AccountStatus {
  ACTIVE
  INACTIVE

  @@map("account_status")
}

enum GradeBand {
  MATERNELLE
  ELEMENTAIRE
  COLLEGE
  LYCEE

  @@map("grade_band")
}

enum DepartmentBand {
  MATERNELLE
  ELEMENTAIRE
  COLLEGE
  LYCEE
  NON_ACADEMIC

  @@map("department_band")
}

enum AssumptionValueType {
  PERCENTAGE
  CURRENCY
  INTEGER
  DECIMAL
  TEXT

  @@map("assumption_value_type")
}

model ChartOfAccount {
  id           Int           @id @default(autoincrement())
  accountCode  String        @unique @map("account_code") @db.VarChar(10)
  accountName  String        @map("account_name") @db.VarChar(100)
  type         AccountType
  ifrsCategory String        @map("ifrs_category") @db.VarChar(100)
  centerType   CenterType    @map("center_type")
  description  String?       @db.VarChar(500)
  status       AccountStatus @default(ACTIVE)
  version      Int           @default(1)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  createdBy    Int           @map("created_by")
  updatedBy    Int           @map("updated_by")

  creator User @relation("AccountCreator", fields: [createdBy], references: [id])
  updater User @relation("AccountUpdater", fields: [updatedBy], references: [id])

  @@map("chart_of_accounts")
}

model AcademicYear {
  id            Int      @id @default(autoincrement())
  fiscalYear    String   @unique @map("fiscal_year") @db.VarChar(6)
  ay1Start      DateTime @map("ay1_start") @db.Date
  ay1End        DateTime @map("ay1_end") @db.Date
  ay2Start      DateTime @map("ay2_start") @db.Date
  ay2End        DateTime @map("ay2_end") @db.Date
  summerStart   DateTime @map("summer_start") @db.Date
  summerEnd     DateTime @map("summer_end") @db.Date
  academicWeeks Int      @map("academic_weeks")
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy     Int      @map("created_by")
  updatedBy     Int      @map("updated_by")

  creator User @relation("AcademicYearCreator", fields: [createdBy], references: [id])
  updater User @relation("AcademicYearUpdater", fields: [updatedBy], references: [id])

  @@map("academic_years")
}

model GradeLevel {
  id           Int       @id @default(autoincrement())
  gradeCode    String    @unique @map("grade_code") @db.VarChar(10)
  gradeName    String    @map("grade_name") @db.VarChar(60)
  band         GradeBand
  maxClassSize Int       @map("max_class_size")
  defaultAy2Intake Int?  @map("default_ay2_intake")
  plancherPct  Decimal   @map("plancher_pct") @db.Decimal(5, 4)
  ciblePct     Decimal   @map("cible_pct") @db.Decimal(5, 4)
  plafondPct   Decimal   @map("plafond_pct") @db.Decimal(5, 4)
  displayOrder Int       @map("display_order")
  version      Int       @default(1)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("grade_levels")
}

model Nationality {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(5)
  label     String   @db.VarChar(100)
  vatExempt Boolean  @default(false) @map("vat_exempt")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy Int      @map("created_by")
  updatedBy Int      @map("updated_by")

  creator User @relation("NationalityCreator", fields: [createdBy], references: [id])
  updater User @relation("NationalityUpdater", fields: [updatedBy], references: [id])

  @@map("nationalities")
}

model Tariff {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(10)
  label       String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy   Int      @map("created_by")
  updatedBy   Int      @map("updated_by")

  creator User @relation("TariffCreator", fields: [createdBy], references: [id])
  updater User @relation("TariffUpdater", fields: [updatedBy], references: [id])

  @@map("tariffs")
}

model Department {
  id          Int            @id @default(autoincrement())
  code        String         @unique @db.VarChar(20)
  label       String         @db.VarChar(100)
  bandMapping DepartmentBand @map("band_mapping")
  version     Int            @default(1)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  createdBy   Int            @map("created_by")
  updatedBy   Int            @map("updated_by")

  creator User @relation("DepartmentCreator", fields: [createdBy], references: [id])
  updater User @relation("DepartmentUpdater", fields: [updatedBy], references: [id])

  @@map("departments")
}

model Assumption {
  id        Int                 @id @default(autoincrement())
  key       String              @unique @db.VarChar(50)
  value     String              @db.VarChar(500)
  unit      String              @db.VarChar(20)
  section   String              @db.VarChar(50)
  label     String              @db.VarChar(100)
  valueType AssumptionValueType @map("value_type")
  version   Int                 @default(1)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy Int?                @map("updated_by")

  updater User? @relation("AssumptionUpdater", fields: [updatedBy], references: [id])

  @@map("assumptions")
}

// ── Version Management (Epic 10) ──────────────────────────────────────────────

model BudgetVersion {
  id                Int      @id @default(autoincrement())
  fiscalYear        Int      @map("fiscal_year") @db.SmallInt
  name              String   @db.VarChar(100)
  type              String   @db.VarChar(10)
  status            String   @default("Draft") @db.VarChar(10)
  description       String?  @db.Text
  dataSource        String   @default("CALCULATED") @map("data_source") @db.VarChar(12)
  sourceVersionId   Int?     @map("source_version_id")
  modificationCount Int      @default(0) @map("modification_count")
  staleModules      String[] @default([]) @map("stale_modules")
  rolloverThreshold Decimal  @default(1.0000) @map("rollover_threshold") @db.Decimal(5, 4)
  cappedRetention   Decimal  @default(0.9800) @map("capped_retention") @db.Decimal(5, 4)
  retentionRecentWeight Decimal @default(0.6000) @map("retention_recent_weight") @db.Decimal(5, 4)
  historicalTargetRecentWeight Decimal @default(0.8000) @map("historical_target_recent_weight") @db.Decimal(5, 4)
  createdById       Int      @map("created_by_id")
  publishedAt       DateTime? @map("published_at") @db.Timestamptz
  lockedAt          DateTime? @map("locked_at") @db.Timestamptz
  archivedAt        DateTime? @map("archived_at") @db.Timestamptz
  updatedById       Int?     @map("updated_by_id")
  lastCalculatedAt  DateTime? @map("last_calculated_at")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  createdBy     User            @relation("VersionCreator", fields: [createdById], references: [id])
  updatedBy     User?           @relation("VersionUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  sourceVersion BudgetVersion?  @relation("VersionCloneSource", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  clones        BudgetVersion[] @relation("VersionCloneSource")

  fiscalPeriods     FiscalPeriod[]
  monthlySummaries  MonthlyBudgetSummary[]
  actualsImportLogs ActualsImportLog[]

  // Enrollment & Capacity (Epic 1)
  enrollmentHeadcounts EnrollmentHeadcount[]
  enrollmentDetails    EnrollmentDetail[]
  dhgRequirements      DhgRequirement[]
  calculationAuditLogs CalculationAuditLog[]
  cohortParameters       CohortParameter[]
  nationalityBreakdowns  NationalityBreakdown[]
  capacityConfigs        VersionCapacityConfig[]

  // Revenue (Epic 2)
  feeGrids           FeeGrid[]
  discountPolicies   DiscountPolicy[]
  revenueSettings    VersionRevenueSettings?
  otherRevenueItems  OtherRevenueItem[]
  monthlyRevenues    MonthlyRevenue[]
  monthlyOtherRevenues MonthlyOtherRevenue[]

  // Staffing (Epic 3)
  employees          Employee[]
  monthlyStaffCosts  MonthlyStaffCost[]
  eosProvisions      EosProvision[]

  // Staff Costs — Category Level (Epic 8)
  categoryMonthlyCosts CategoryMonthlyCost[]

  @@unique([fiscalYear, name], map: "uq_budget_version_name_fy")
  @@index([fiscalYear], map: "idx_budget_versions_fiscal_year")
  @@index([status], map: "idx_budget_versions_status")
  @@index([sourceVersionId], map: "idx_budget_versions_source")
  @@index([createdById], map: "idx_budget_versions_created_by")
  @@index([updatedById], map: "idx_budget_versions_updated_by")
  @@map("budget_versions")
}

model FiscalPeriod {
  id              Int       @id @default(autoincrement())
  fiscalYear      Int       @map("fiscal_year") @db.SmallInt
  month           Int       @db.SmallInt
  status          String    @default("Draft") @db.VarChar(10)
  actualVersionId Int?      @map("actual_version_id")
  lockedAt        DateTime? @map("locked_at") @db.Timestamptz
  lockedById      Int?      @map("locked_by_id")
  updatedById     Int?      @map("updated_by_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  actualVersion BudgetVersion? @relation(fields: [actualVersionId], references: [id], onDelete: SetNull)
  lockedBy      User?          @relation("FiscalPeriodLocker", fields: [lockedById], references: [id], onDelete: SetNull)
  updatedBy     User?          @relation("FiscalPeriodUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([fiscalYear, month], map: "uq_fiscal_period")
  @@index([fiscalYear], map: "idx_fiscal_periods_fiscal_year")
  @@index([actualVersionId], map: "idx_fiscal_periods_actual_version")
  @@index([lockedById], map: "idx_fiscal_periods_locked_by")
  @@index([updatedById], map: "idx_fiscal_periods_updated_by")
  @@map("fiscal_periods")
}

model MonthlyBudgetSummary {
  id           Int      @id @default(autoincrement())
  versionId    Int      @map("version_id")
  month        Int      @db.SmallInt
  revenueHt    Decimal  @default(0) @map("revenue_ht") @db.Decimal(15, 4)
  staffCosts   Decimal  @default(0) @map("staff_costs") @db.Decimal(15, 4)
  netProfit    Decimal  @default(0) @map("net_profit") @db.Decimal(15, 4)
  calculatedAt DateTime @default(now()) @map("calculated_at") @db.Timestamptz

  version BudgetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, month], map: "uq_monthly_summary")
  @@index([versionId], map: "idx_monthly_summary_version")
  @@map("monthly_budget_summary")
}

model ActualsImportLog {
  id               Int      @id @default(autoincrement())
  versionId        Int      @map("version_id")
  module           String   @db.VarChar(12)
  sourceFile       String   @map("source_file") @db.VarChar(255)
  validationStatus String   @map("validation_status") @db.VarChar(10)
  rowsImported     Int      @default(0) @map("rows_imported")
  importedById     Int      @map("imported_by_id")
  importedAt       DateTime @default(now()) @map("imported_at") @db.Timestamptz

  version    BudgetVersion @relation(fields: [versionId], references: [id])
  importedBy User          @relation("ActualsImporter", fields: [importedById], references: [id])

  @@map("actuals_import_log")
}

// ── Enrollment & Capacity (Epic 1) ───────────────────────────────────────────

model EnrollmentHeadcount {
  id             Int      @id @default(autoincrement())
  versionId      Int      @map("version_id")
  academicPeriod String   @map("academic_period") @db.VarChar(3)
  gradeLevel     String   @map("grade_level") @db.VarChar(10)
  headcount      Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      Int      @map("created_by")
  updatedBy      Int?     @map("updated_by")

  version    BudgetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  creator    User          @relation("HeadcountCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  updater    User?         @relation("HeadcountUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  details    EnrollmentDetail[]

  @@unique([versionId, academicPeriod, gradeLevel], map: "uq_enrollment_headcount")
  @@index([versionId, academicPeriod], map: "idx_enrollment_headcount_version_period")
  @@map("enrollment_headcount")
}

model EnrollmentDetail {
  id             Int      @id @default(autoincrement())
  versionId      Int      @map("version_id")
  academicPeriod String   @map("academic_period") @db.VarChar(3)
  gradeLevel     String   @map("grade_level") @db.VarChar(10)
  nationality    String   @db.VarChar(10)
  tariff         String   @db.VarChar(10)
  headcount      Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy      Int      @map("created_by")
  updatedBy      Int?     @map("updated_by")

  version        BudgetVersion       @relation(fields: [versionId], references: [id], onDelete: Cascade)
  headcountEntry EnrollmentHeadcount @relation(fields: [versionId, academicPeriod, gradeLevel], references: [versionId, academicPeriod, gradeLevel], onDelete: Cascade)
  creator        User                @relation("DetailCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  updater        User?               @relation("DetailUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([versionId, academicPeriod, gradeLevel, nationality, tariff], map: "uq_enrollment_detail")
  @@index([versionId, academicPeriod, gradeLevel], map: "idx_enrollment_detail_version_period_grade")
  @@map("enrollment_detail")
}

// ── DHG & Calculation Audit (Epic 1) ──────────────────────────────────────────

model DhgRequirement {
  id              Int      @id @default(autoincrement())
  versionId       Int      @map("version_id")
  academicPeriod  String   @map("academic_period") @db.VarChar(3)
  gradeLevel      String   @map("grade_level") @db.VarChar(10)
  headcount       Int      @default(0)
  maxClassSize    Int      @map("max_class_size")
  sectionsNeeded  Int      @default(0) @map("sections_needed")
  utilization     Decimal  @default(0) @db.Decimal(5, 1)
  alert           String?  @db.VarChar(10)
  recruitmentSlots Int     @default(0) @map("recruitment_slots")
  totalWeeklyHours Decimal @default(0) @map("total_weekly_hours") @db.Decimal(10, 4)
  totalAnnualHours Decimal @default(0) @map("total_annual_hours") @db.Decimal(10, 4)
  fte              Decimal @default(0) @db.Decimal(7, 4)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  version BudgetVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, academicPeriod, gradeLevel], map: "uq_dhg_requirement")
  @@index([versionId], map: "idx_dhg_requirements_version")
  @@map("dhg_requirements")
}

model CalculationAuditLog {
  id            Int       @id @default(autoincrement())
  versionId     Int?      @map("version_id")
  runId         String    @map("run_id") @db.Uuid
  module        String    @default("ENROLLMENT") @db.VarChar(20)
  status        String    @default("STARTED") @db.VarChar(20)
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  durationMs    Int?      @map("duration_ms")
  inputSummary  Json?     @map("input_summary") @db.JsonB
  outputSummary Json?     @map("output_summary") @db.JsonB
  triggeredBy   Int?      @map("triggered_by")

  version   BudgetVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  triggerer User?         @relation("CalculationTriggeredBy", fields: [triggeredBy], references: [id])

  @@index([versionId], map: "idx_calc_audit_version")
  @@index([runId], map: "idx_calc_audit_run_id")
  @@index([module, status], map: "idx_calc_audit_module_status")
  @@index([triggeredBy], map: "idx_calc_audit_triggered_by")
  @@map("calculation_audit_log")
}

// ── Cohort & Nationality (Enrollment Refactor) ───────────────────────────────

model CohortParameter {
  id                Int      @id @default(autoincrement())
  versionId         Int      @map("version_id")
  gradeLevel        String   @map("grade_level") @db.VarChar(10)
  retentionRate     Decimal  @default(0.97) @map("retention_rate") @db.Decimal(5, 4)
