{
	"name": "@budfin/api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"db:bootstrap": "set -a && . .env && set +a && prisma migrate deploy && prisma db seed",
		"dev": "pnpm run db:bootstrap && tsx watch --env-file=.env src/index.ts",
		"build": "tsc",
		"lint": "eslint src",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"migrate": "tsx src/migration/index.ts",
		"backfill:enrollment-history": "tsx --env-file=.env src/migration/backfill-enrollment-history.ts",
		"parse:staff-costs": "tsx src/migration/parse-staff-costs-excel.ts"
	},
	"dependencies": {
		"@budfin/types": "workspace:*",
		"@date-fns/tz": "^1.0.0",
		"@fastify/cookie": "^11.0.0",
		"@fastify/cors": "^10.0.0",
		"@fastify/jwt": "^9.0.0",
		"@fastify/multipart": "^9.4.0",
		"@fastify/rate-limit": "^10.0.0",
		"@prisma/client": "^6.0.0",
		"@react-pdf/renderer": "^4.3.0",
		"bcryptjs": "^3.0.0",
		"date-fns": "^4.0.0",
		"decimal.js": "^10.6.0",
		"exceljs": "^4.4.0",
		"fast-csv": "^5.0.0",
		"fastify": "^5.7.0",
		"fastify-plugin": "^5.0.0",
		"fastify-type-provider-zod": "^6.0.0",
		"jose": "^5.0.0",
		"papaparse": "^5.5.3",
		"pg-boss": "^10.0.0",
		"prisma": "^6.0.0",
		"prom-client": "^15.1.0",
		"winston": "^3.19.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^22.0.0",
		"@types/papaparse": "^5.5.2",
		"@vitest/coverage-v8": "^4.0.18",
		"tsx": "^4.21.0",
		"vitest": "^4.0.0"
	}
}
